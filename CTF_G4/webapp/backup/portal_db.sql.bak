-- GrandMaster Analysis Portal - database export
-- Generated during the 2024 migration to chessmaster.local
-- DO NOT leave this in the webroot (TODO: move to off-host storage)

CREATE TABLE members (
  id       INT PRIMARY KEY,
  username VARCHAR(32) NOT NULL,
  password VARCHAR(64) NOT NULL,   -- md5crypt
  role     VARCHAR(16) DEFAULT 'member',
  title    VARCHAR(8),
  joined   DATE
);

